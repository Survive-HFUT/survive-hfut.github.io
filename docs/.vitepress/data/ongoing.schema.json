{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "ongoing.schema.json",
  "title": "Ongoing Events",
  "type": "object",
  "additionalProperties": false,
  "required": ["$schema", "events"],
  "properties": {
    "$schema": {
      "const": "./ongoing.schema.json"
    },
    "events": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/event"
      }
    }
  },
  "$defs": {
    "event": {
      "type": "object",
      "additionalProperties": false,
      "required": ["title", "campus", "start", "end", "href"],
      "properties": {
        "title": {
          "type": "string",
          "minLength": 1
        },
        "campus": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {
            "enum": ["宣城校区", "屯溪路校区", "翡翠湖校区"]
          }
        },
        "start": {
          "type": "string",
          "minLength": 1
        },
        "end": {
          "type": "string",
          "minLength": 1
        },
        "href": {
          "type": "string",
          "minLength": 1
        },
        "note": {
          "type": "string"
        }
      }
    }
  }
}
