{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "ongoing.schema.json",
  "title": "Ongoing Events",
  "type": "object",
  "additionalProperties": false,
  "required": ["$schema", "events"],
  "properties": {
    "$schema": {
      "title": "Schema Reference",
      "const": "./ongoing.schema.json"
    },
    "events": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/event"
      }
    }
  },
  "$defs": {
    "event": {
      "type": "object",
      "additionalProperties": false,
      "required": ["title", "campus", "start", "end", "href"],
      "properties": {
        "title": {
          "title": "标题",
          "type": "string",
          "minLength": 1
        },
        "campus": {
          "title": "校区",
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {
            "enum": ["宣城校区", "屯溪路校区", "翡翠湖校区"]
          }
        },
        "start": {
          "title": "开始日期",
          "type": "string",
          "minLength": 1,
          "pattern": "^\\d{4}-\\d{2}-\\d{2}( \\d{2}:\\d{2})?$"
        },
        "end": {
          "title": "结束日期",
          "type": "string",
          "minLength": 1,
          "pattern": "^\\d{4}-\\d{2}-\\d{2}( \\d{2}:\\d{2})?$"
        },
        "href": {
          "title": "链接",
          "type": "string",
          "minLength": 1
        },
        "note": {
          "title": "备注",
          "type": "string"
        }
      }
    }
  }
}
